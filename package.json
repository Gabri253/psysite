{
  "name": "psysite",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run tailwind:watch\" \"eleventy --serve\"",
    "build": "npm run tailwind:build && eleventy",
    "tailwind:watch": "npx tailwindcss -i src/assets/css/style.css -o _site/assets/css/output.css --watch",
    "tailwind:build": "npx tailwindcss -i src/assets/css/style.css -o _site/assets/css/output.css --minify",
    "serve": "eleventy --serve",
    "watch": "eleventy --watch",
    "debug": "DEBUG=Eleventy* eleventy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
