---
layout: "base.njk"
---

  <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {% for post in sanityPosts %}
    <article class="border p-4 rounded-lg">
      <h2 class="font-serif text-2xl text-brand-forest">{{ post.title }}</h2>
      <p class="text-gray-600">{{ post.publishedAt | formatDate }}</p>
      
      {# Se hai un abstract/descrizione breve #}
      <p class="my-4">{{ post.description }}</p>
      
      <a href="/blog/{{ post.slug }}/" class="text-brand-sage font-bold">
        Leggi l'articolo →
      </a>
    </article>
  {% endfor %}
</section>