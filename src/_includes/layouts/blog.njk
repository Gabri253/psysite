---
layout: "base.njk"
---

<div class="grid gap-8">
    {% for post in collections.posts | reverse %}
      <article class="flex flex-col md:flex-row gap-6 border-b border-gray-100 pb-8">
        <div class="flex-1">
          <h2 class="text-2xl font-semibold hover:text-teal-600 transition">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h2>
          <p class="text-gray-500 text-sm mb-3">
            {{ post.data.date }} </p>
          <p class="text-gray-600 leading-relaxed">
            {{ post.data.description or post.templateContent | truncate(150) | safe }}
          </p>
          <a href="{{ post.url }}" class="inline-block mt-4 text-teal-700 font-medium">
            Leggi l'articolo &rarr;
          </a>
        </div>
      </article>
    {% endfor %}
  </div>